<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_smart_replenishment_search" model="ir.ui.view">
        <field name="name">smart.replenishment.search</field>
        <field name="model">smart.replenishment.dashboard</field>
        <field name="arch" type="xml">
            <search string="Análisis de Rotación">
                <filter string="Clase A (Alta Rotación)" name="filter_class_a" domain="[('rotation_classification', '=', 'a')]"/>
                <filter string="Clase B (Media Rotación)" name="filter_class_b" domain="[('rotation_classification', '=', 'b')]"/>
                <filter string="Clase C (Baja Rotación)" name="filter_class_c" domain="[('rotation_classification', '=', 'c')]"/>
                <separator/>
                <filter string="Este Mes" name="this_month" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <filter string="Este Año" name="this_year" domain="[('date', '&gt;=', context_today().strftime('%Y-01-01'))]"/>
                
                <group expand="1" string="Agrupar Por">
                    <filter string="Producto" name="group_product" context="{'group_by':'product_id'}"/>
                    <filter string="Categoría" name="group_category" context="{'group_by':'categ_id'}"/>
                    <filter string="Clasificación" name="group_classification" context="{'group_by':'rotation_classification'}"/>
                    <filter string="Fecha (Mes)" name="group_date_month" context="{'group_by':'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_smart_replenishment_graph" model="ir.ui.view">
        <field name="name">smart.replenishment.graph</field>
        <field name="model">smart.replenishment.dashboard</field>
        <field name="arch" type="xml">
            <graph string="Análisis de Ingresos por Rotación" type="bar">
                <field name="product_id"/>
                <field name="revenue" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_smart_replenishment_pivot" model="ir.ui.view">
        <field name="name">smart.replenishment.pivot</field>
        <field name="model">smart.replenishment.dashboard</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Rotación">
                <field name="rotation_classification" type="row"/>
                <field name="product_id" type="row"/>
                <field name="date" interval="month" type="col"/>
                <field name="qty_sold" type="measure"/>
                <field name="revenue" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_smart_replenishment_dashboard" model="ir.actions.act_window">
            <field name="name">Análisis de Rotación</field>
            <field name="res_model">smart.replenishment.dashboard</field>
            <field name="view_mode">pivot,graph</field>
            <field name="search_view_id" ref="view_smart_replenishment_search"/>
            <field name="context">{'search_default_this_month': 1}</field>
        </record>

        <menuitem id="menu_smart_replenishment_root" 
                name="Smart Stock" 
                parent="purchase.menu_purchase_root" 
                sequence="15"/>

        <menuitem id="menu_smart_replenishment_dashboard" 
                name="Dashboard de Rotación" 
                parent="menu_smart_replenishment_root" 
                action="action_smart_replenishment_dashboard" 
                sequence="1"/>

</odoo>