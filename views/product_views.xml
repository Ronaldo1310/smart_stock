<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_smart_stock" model="ir.ui.view">
        <field name="name">product.template.form.inherit.smart.stock</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Smart Replenishment">
                    <group>
                        <group string="Classification">
                            <field name="rotation_classification" readonly="1"/>
                            <field name="is_seasonal"/>
                        </group>
                        <group string="Replenishment Variables">
                            <field name="safety_stock_days"/>
                            <field name="last_purchase_cost" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <record id="view_product_product_form_inherit_smart_stock" model="ir.ui.view">
        <field name="name">product.product.form.inherit.smart.stock</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Smart Replenishment">
                    <group>
                        <group string="Actual Costs (Variant)">
                            <field name="last_purchase_cost" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group string="Demand Forecast (Variant)">
                            <field name="smoothing_alpha"/>
                            <field name="last_forecasted_demand"/>
                            <field name="current_forecasted_demand"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>